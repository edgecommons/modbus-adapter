        "publish": { "batchMs": 0 },
        "write": { "enabled": true },
        "pollGroups": [
          {
            "id": "main", "pollIntervalMs": 500, "unitId": 1, "publishMode": "onChange", "maxGap": 4,
            "signals": [
              { "name": "Counter16", "table": "holding", "address": 0, "type": "uint16" },
              { "name": "Temp", "table": "holding", "address": 1, "type": "float32", "deadband": { "type": "absolute", "value": 0.1 } },
              { "name": "InCounter", "table": "input", "address": 0, "type": "uint16" },
              { "name": "StatusBit", "table": "discrete", "address": 0, "type": "bool" },
              { "name": "RunCmd", "table": "coil", "address": 0, "type": "bool" },
              { "name": "Scaled", "table": "holding", "address": 40, "type": "uint16", "scale": 0.1 },
              { "name": "Alarm3", "table": "holding", "address": 41, "type": "bool", "bit": 3 },
              { "name": "RWInt16", "table": "holding", "address": 10, "type": "int16" },
              { "name": "RWUInt16", "table": "holding", "address": 11, "type": "uint16" },
              { "name": "RWInt32", "table": "holding", "address": 12, "type": "int32" },
              { "name": "RWUInt32", "table": "holding", "address": 14, "type": "uint32" },
              { "name": "RWInt64", "table": "holding", "address": 16, "type": "int64" },
              { "name": "RWUInt64", "table": "holding", "address": 20, "type": "uint64" },
              { "name": "RWFloat32", "table": "holding", "address": 24, "type": "float32" },
              { "name": "RWFloat64", "table": "holding", "address": 26, "type": "float64" },
              { "name": "RWString", "table": "holding", "address": 30, "type": "string", "count": 4 }
            ]
          }
        ]
      }
    ]
  }
}
