{
  "tags": { "appId": "modbus", "site": "lab", "shop": "s1", "line": "l1" },
  "hierarchy": { "levels": ["site", "shop", "line", "device"] },
  "identity": { "site": "lab", "shop": "s1", "line": "l1" },
