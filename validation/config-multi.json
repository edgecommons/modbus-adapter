{
  "tags": { "appId": "modbus", "site": "lab", "shop": "s1", "line": "l1" },
  "logging": { "level": "INFO" },
  "metricEmission": {
    "target": "messaging",
    "targetConfig": { "topic": "metrics/{ThingName}/{ComponentName}" }
  },
  "component": {
    "global": { "defaults": { "pollIntervalMs": 500, "publishMode": "onChange", "batchMs": 0 } },
    "instances": [
      {
        "id": "plc1",
        "adapter": "modbus",
        "connection": { "transport": "tcp", "host": "127.0.0.1", "port": 5020, "unitId": 1, "timeoutMs": 1000 },
        "publish": { "topic": "southbound/{site}/{ComponentName}/{InstanceId}/{tagId}", "batchMs": 0 },
        "write": { "enabled": true, "topic": "southbound/{ComponentName}/{InstanceId}/write" },
        "read": { "topic": "southbound/{ComponentName}/{InstanceId}/read" },
        "pollGroups": [
          { "id": "g", "pollIntervalMs": 500,
            "tags": [
              { "name": "Counter16", "table": "holding", "address": 0, "type": "uint16" },
              { "name": "Scaled", "table": "holding", "address": 40, "type": "uint16", "scale": 0.1 }
            ] }
        ]
      },
      {
        "id": "plc2",
        "adapter": "modbus",
        "connection": { "transport": "tcp", "host": "127.0.0.1", "port": 5021, "unitId": 1, "timeoutMs": 1000 },
        "publish": { "topic": "southbound/{site}/{ComponentName}/{InstanceId}/{tagId}", "batchMs": 0 },
        "write": { "enabled": true, "topic": "southbound/{ComponentName}/{InstanceId}/write" },
        "read": { "topic": "southbound/{ComponentName}/{InstanceId}/read" },
        "pollGroups": [
          { "id": "g", "pollIntervalMs": 500,
            "tags": [
              { "name": "Counter16", "table": "holding", "address": 0, "type": "uint16" },
              { "name": "Scaled", "table": "holding", "address": 40, "type": "uint16", "scale": 0.1 }
            ] }
        ]
      }
    ]
  }
}
